{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aipkg.dev/schema/aipkg.json",
  "title": "aipkg package manifest",
  "description": "Schema for package-type aipkg.json manifest files.",
  "type": "object",
  "required": ["specVersion", "name", "version"],
  "properties": {
    "specVersion": {
      "description": "Package format specification version.",
      "type": "integer",
      "const": 1
    },
    "name": {
      "description": "Scoped package name (@scope/package-name).",
      "type": "string",
      "pattern": "^@(?!.*--)[a-z0-9]([a-z0-9-]{0,37}[a-z0-9])?/[a-z0-9]([a-z0-9-]{0,62}[a-z0-9])?$"
    },
    "version": {
      "description": "Package version. Strict semver (MAJOR.MINOR.PATCH).",
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
    },
    "description": {
      "description": "Short summary of the package.",
      "type": "string",
      "maxLength": 255
    },
    "license": {
      "description": "SPDX license identifier or \"proprietary\".",
      "type": "string"
    },
    "artifacts": {
      "description": "Artifacts contained in this package. Generated by aipkg pack.",
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "artifact": {
      "type": "object",
      "required": ["name", "type", "path"],
      "properties": {
        "name": {
          "description": "Artifact name within the package.",
          "type": "string",
          "pattern": "^(?!.*--)[a-z0-9]([a-z0-9-]{0,62}[a-z0-9])?$"
        },
        "type": {
          "description": "Artifact type.",
          "enum": ["skill", "prompt", "command", "agent", "agent-instructions", "mcp-server"]
        },
        "path": {
          "description": "Relative path to the artifact file or directory.",
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
